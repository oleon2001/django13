# SkyGuard Frontend Environment Variables

# API Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_API_TIMEOUT=30000

# Authentication
REACT_APP_AUTH_STORAGE_KEY=skyguard_auth
REACT_APP_TOKEN_REFRESH_INTERVAL=300000

# Real-time Configuration
REACT_APP_WEBSOCKET_URL=ws://localhost:8000/ws/
REACT_APP_POLLING_INTERVAL=30000

# Development
REACT_APP_ENABLE_DEVTOOLS=true
REACT_APP_ENABLE_MOCK_DATA=false

# Feature Flags
REACT_APP_ENABLE_GEOFENCING=true
REACT_APP_ENABLE_TRACKING=true
REACT_APP_ENABLE_REPORTS=true
REACT_APP_ENABLE_PARKING=true

# Map Configuration
REACT_APP_MAP_API_KEY=your_map_api_key_here
REACT_APP_MAP_CENTER_LAT=40.7128
REACT_APP_MAP_CENTER_LNG=-74.0060
REACT_APP_MAP_ZOOM=10

# Notifications
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=false
REACT_APP_PUSH_PUBLIC_KEY=your_push_public_key_here

# Analytics
REACT_APP_ANALYTICS_ID=your_analytics_id_here
REACT_APP_ENABLE_ANALYTICS=false 